@using EduConnect.Interfaces
@using EduConnect.Models.Enums
@namespace EduConnect.Components.Auth

@implements IDisposable

<nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow-sm"
     style="background-color: var(--brand-navy); border-bottom: 3px solid var(--brand-gold);">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-flex align-items-center" href="/">
            <img src="favicon.png" alt="EduConnect Logo" width="40" height="40"
                 class="me-2 rounded-circle bg-white p-1">
            <span class="fw-bold">EduConnect</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                @if (CurrentUser != null)
                {
                    <li class="nav-item">
                        <span class="navbar-text me-3">
                            @CurrentUser.FullName
                            <span class="badge bg-primary">@CurrentUser.Role</span>
                        </span>
                    </li>

                    @if (CurrentUser.Role == UserRole.Admin)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/admin/students">Students</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin/courses">Courses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin/reports/grades">Grade Reports</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin/notifications">Announcements</a>
                        </li>
                    }

                    @if (CurrentUser.Role == UserRole.Faculty)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/faculty/courses">My Courses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/faculty/grades">Grade Entry</a>
                        </li>
                    }

                    @if (CurrentUser.Role == UserRole.Student)
                    {
                        <li class="nav-item">
                            <a class="nav-link position-relative" href="/student/enroll">
                                Enroll
                                @if (EnrolledCredits > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-info">
                                        @EnrolledCredits cr
                                    </span>
                                }
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/courses">Catalog</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/student/grades">My Grades</a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link" href="/notifications">
                            📬 Notifications
                        </a>
                    </li>

                    <li class="nav-item">
                        <button class="btn btn-outline-light btn-sm" @onclick="HandleLogout">Logout</button>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Login</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@code {
    [Inject]
    private IAuthStateService? AuthStateService { get; set; }

    [Inject]
    private ICourseService? CourseService { get; set; }

    [Inject]
    private NavigationManager? NavigationManager { get; set; }

    private Person? CurrentUser => AuthStateService?.CurrentUser;
    private int EnrolledCredits => ComputeEnrolledCredits();

    protected override void OnInitialized()
    {
        if (AuthStateService != null)
        {
            AuthStateService.OnAuthStateChanged += StateChanged;
        }

        if (CourseService != null)
        {
            CourseService.OnEnrollmentChanged += OnEnrollmentChanged;
        }
    }

    private int ComputeEnrolledCredits()
    {
        if (CurrentUser?.Role != UserRole.Student || CourseService == null)
            return 0;

        var allCourses = CourseService.GetAll();
        var enrolledCredits = allCourses
            .Where(c => c.EnrolledStudentIds.Contains(CurrentUser.Id))
            .Sum(c => c.CreditHours);

        return enrolledCredits;
    }

    private void StateChanged()
    {
        StateHasChanged();
    }

    private void OnEnrollmentChanged()
    {
        StateHasChanged();
    }

    private void HandleLogout()
    {
        AuthStateService?.Logout();
        NavigationManager?.NavigateTo("/login", forceLoad: true);
    }

    void IDisposable.Dispose()
    {
        if (AuthStateService != null)
        {
            AuthStateService.OnAuthStateChanged -= StateChanged;
        }

        if (CourseService != null)
        {
            CourseService.OnEnrollmentChanged -= OnEnrollmentChanged;
        }
    }
}

@using EduConnect.Interfaces
@using EduConnect.Models.Enums
@namespace EduConnect.Components.Auth

@implements IDisposable

<nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow"
     style="background-color: var(--brand-navy); border-bottom: 3px solid var(--brand-gold);">
    <div class="container-fluid px-3 px-lg-4">

        @* Brand *@
        <a class="navbar-brand d-flex align-items-center gap-2 py-2" href="/dashboard">
            <img src="favicon.png" alt="EduConnect Logo" width="38" height="38"
                 class="rounded-circle bg-white p-1 flex-shrink-0">
            <span class="fw-bold fs-5 lh-1">EduConnect</span>
        </a>

        @* Right-side Actions (Bell + Toggler) *@
        <div class="d-flex align-items-center gap-2 ms-auto order-lg-last">
            @if (CurrentUser != null)
            {
                @* Mobile/Tablet Bell (hidden on lg) *@
                <div class="d-lg-none">
                    <EduConnect.Components.Shared.NotificationBell />
                </div>
            }

            @* Toggler (mobile only) *@
            <button class="navbar-toggler border-0 p-1 ms-2" type="button" @onclick="ToggleMenu"
                    aria-label="Toggle navigation" aria-expanded="@IsMenuOpen">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>

        @* Collapsible content *@
        <div class="@($"collapse navbar-collapse {(IsMenuOpen ? "show" : "")}")">

            @if (CurrentUser != null)
            {
                @* Nav links *@
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @* ... (rest of nav links) ... *@
                    @if (CurrentUser.Role == UserRole.Admin)
                    {
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/admin/students">Students</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/admin/courses">Courses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/admin/reports/grades">Grade Reports</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/admin/notifications">Announcements</a>
                        </li>
                    }
                    @if (CurrentUser.Role == UserRole.Faculty)
                    {
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/faculty/courses">My Courses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/faculty/grades">Grade Entry</a>
                        </li>
                    }
                    @if (CurrentUser.Role == UserRole.Student)
                    {
                        <li class="nav-item">
                            <a class="nav-link px-3 position-relative" href="/student/enroll">
                                Enroll
                                @if (EnrolledCredits > 0)
                                {
                                    <span
                                        class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary text-white">
                                        @EnrolledCredits cr
                                    </span>
                                }
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/student/enrolled-courses">My Courses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/courses">Catalog</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/student/grades">My Grades</a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link px-3" href="/notifications">Notifications</a>
                    </li>
                </ul>

                @* Divider visible on mobile only *@
                <hr class="d-lg-none border-secondary my-2" />

                @* User info + logout *@
                <div
                    class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-3 pb-2 pb-lg-0 ms-lg-3">
                    
                    @* Desktop Bell (hidden on mobile) *@
                    <div class="d-none d-lg-block me-2">
                        <EduConnect.Components.Shared.NotificationBell />
                    </div>

                    <div class="d-flex align-items-center gap-2 border-start border-white border-opacity-10 ps-3">
                        <div class="bg-white bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center fw-bold text-white flex-shrink-0"
                             style="width:36px; height:36px; font-size:0.85rem; border: 1px solid rgba(255,255,255,0.1);">
                            @GetInitials(CurrentUser.FullName)
                        </div>
                        <div class="lh-1 text-nowrap">
                            <div class="text-white fw-bold small mb-1">@CurrentUser.FullName</div>
                            <span class="badge bg-accent text-white border-0 shadow-sm" style="font-size: 0.65rem; padding: 0.35em 0.65em; letter-spacing: 0.5px;">@CurrentUser.Role.ToString().ToUpper()</span>
                        </div>
                    </div>
                    <button class="btn btn-outline-light btn-sm w-100 w-lg-auto" @onclick="HandleLogout">
                        Logout
                    </button>
                </div>
            }


            else
            {
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Login</a>
                    </li>
                </ul>
            }

        </div>
    </div>
</nav>

@code {
    [Inject]
    private IAuthStateService? AuthStateService { get; set; }

    [Inject]
    private ICourseService? CourseService { get; set; }

    [Inject]
    private NavigationManager? NavigationManager { get; set; }

    private Person? CurrentUser => AuthStateService?.CurrentUser;
    private int EnrolledCredits => ComputeEnrolledCredits();
    private bool IsMenuOpen = false;

    protected override void OnInitialized()
    {
        if (AuthStateService != null)
            AuthStateService.OnAuthStateChanged += StateChanged;

        if (CourseService != null)
            CourseService.OnEnrollmentChanged += OnEnrollmentChanged;

        if (NavigationManager != null)
            NavigationManager.LocationChanged += OnLocationChanged;
    }

    private int ComputeEnrolledCredits()
    {
        if (CurrentUser?.Role != UserRole.Student || CourseService == null)
            return 0;

        return CourseService.GetAll()
            .Where(c => c.EnrolledStudentIds.Contains(CurrentUser.Id))
            .Sum(c => c.CreditHours);
    }

    private string GetInitials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "?";
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private void ToggleMenu() => IsMenuOpen = !IsMenuOpen;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        IsMenuOpen = false;
        StateHasChanged();
    }

    private void StateChanged() => InvokeAsync(StateHasChanged);
    private void OnEnrollmentChanged() => InvokeAsync(StateHasChanged);


    private void HandleLogout()
    {
        AuthStateService?.Logout();
        NavigationManager?.NavigateTo("/login", forceLoad: true);
    }

    void IDisposable.Dispose()
    {
        if (AuthStateService != null)
            AuthStateService.OnAuthStateChanged -= StateChanged;

        if (CourseService != null)
            CourseService.OnEnrollmentChanged -= OnEnrollmentChanged;

        if (NavigationManager != null)
            NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

@page "/dashboard"
@using EduConnect.Interfaces
@using EduConnect.Models.Enums
@namespace EduConnect.Components.Pages

@inject IAuthStateService AuthStateService
@inject IStudentService StudentService

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-primary text-white shadow-sm border-0" style="background: linear-gradient(135deg, var(--brand-navy) 0%, var(--brand-blue) 100%);">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h2 class="fw-bold mb-1">Dashboard</h2>
                        <p class="mb-0 text-white-50 fs-5">Welcome back, @(AuthStateService.CurrentUser?.FullName ?? "User")!</p>
                    </div>
                    <div class="d-none d-md-block">
                        <i class="bi bi-speedometer2" style="font-size: 3rem; opacity: 0.8;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (AuthStateService.CurrentUser?.Role == UserRole.Admin)
    {
        <AdminDashboard />
    }
    else if (AuthStateService.CurrentUser?.Role == UserRole.Faculty)
    {
        <FacultyDashboard />
    }
    else if (AuthStateService.CurrentUser?.Role == UserRole.Student)
    {
        <StudentDashboard />
    }
</div>

@code {
    protected override void OnInitialized()
    {
        if (AuthStateService.CurrentUser == null)
        {
            // This would normally redirect to login, but for now we'll let the auth guard handle it
        }
    }
}

@page "/admin/students/add"

<PageTitle>EduConnect - Add Student</PageTitle>

@using EduConnect.Interfaces
@using EduConnect.Models
@using EduConnect.Models.Enums
@namespace EduConnect.Components.Pages.Admin

@inject IStudentService StudentService
@inject IAuthStateService AuthStateService
@inject NavigationManager NavigationManager

<AuthGuard AllowedRoles="new[] { UserRole.Admin }">
    <div class="container mt-4">
        <h2>Add New Student</h2>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }

        <div class="card">
            <div class="card-body">
                <form @onsubmit="HandleSubmit">
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" @bind="newStudent.FullName" />
                        @if (ValidationErrors.Contains("name"))
                        {
                            <small class="text-danger">Full name is required.</small>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" @bind="newStudent.Email" />
                        @if (ValidationErrors.Contains("email"))
                        {
                            <small class="text-danger">Email is required and must be valid.</small>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Semester</label>
                        <select class="form-control" @bind="newStudent.Semester">
                            @for (int i = 1; i <= 8; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                        @if (ValidationErrors.Contains("semester"))
                        {
                            <small class="text-danger">Semester must be between 1 and 8.</small>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" @bind="newStudent.PasswordHash" />
                        @if (ValidationErrors.Contains("password"))
                        {
                            <small class="text-danger">Password is required.</small>
                        }
                    </div>

                    <button type="submit" class="btn btn-primary">Add Student</button>
                    <a href="/admin/students" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</AuthGuard>

@code {
    private Student newStudent = new();
    private string ErrorMessage = string.Empty;
    private List<string> ValidationErrors = new();

    protected override void OnInitialized()
    {
        newStudent.Role = UserRole.Student;
    }

    private void HandleSubmit()
    {
        ErrorMessage = string.Empty;
        ValidationErrors.Clear();

        var validationResult = newStudent.Validate();
        if (!validationResult.IsValid)
        {
            ValidationErrors = validationResult.Errors;
            return;
        }

        try
        {
            StudentService.Add(newStudent);
            AuthStateService.RegisterUser(newStudent);
            NavigationManager.NavigateTo("/admin/students");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}

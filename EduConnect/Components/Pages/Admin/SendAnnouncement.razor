@page "/admin/notifications"

<PageTitle>EduConnect - Send Announcement</PageTitle>

@using EduConnect.Interfaces
@using EduConnect.Models
@using EduConnect.Models.Enums
@namespace EduConnect.Components.Pages.Admin

@inject INotificationService NotificationService
@inject IAuthStateService AuthStateService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <h2>Send Announcements</h2>

    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            @SuccessMessage
            <button type="button" class="btn-close" @onclick="ClearSuccess"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <form @onsubmit="HandleSubmit">
                <div class="mb-3">
                    <label for="message" class="form-label">Message</label>
                    <textarea class="form-control" id="message" @bind="Message" rows="4"
                              placeholder="Enter your announcement message"></textarea>
                    @if (string.IsNullOrEmpty(Message))
                    {
                        <small class="text-muted">Message is required.</small>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Send to Roles</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="adminCheck" @bind="SendToAdmin" />
                        <label class="form-check-label" for="adminCheck">
                            Admin
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="facultyCheck" @bind="SendToFaculty" />
                        <label class="form-check-label" for="facultyCheck">
                            Faculty
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="studentCheck" @bind="SendToStudent" />
                        <label class="form-check-label" for="studentCheck">
                            Student
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">Send Announcement</button>
            </form>
        </div>
    </div>
</div>

@code {
    private string Message = string.Empty;
    private bool SendToAdmin = false;
    private bool SendToFaculty = false;
    private bool SendToStudent = false;
    private string SuccessMessage = string.Empty;

    protected override void OnInitialized()
    {
        if (AuthStateService.CurrentUser?.Role != UserRole.Admin)
        {
            NavigationManager.NavigateTo("/unauthorized");
            return;
        }
    }

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(Message))
            return;

        if (!SendToAdmin && !SendToFaculty && !SendToStudent)
            return;

        var rolesSelected = new List<UserRole>();
        if (SendToAdmin) rolesSelected.Add(UserRole.Admin);
        if (SendToFaculty) rolesSelected.Add(UserRole.Faculty);
        if (SendToStudent) rolesSelected.Add(UserRole.Student);

        var allUsers = AuthStateService.GetAllUsers();
        var targetUsers = allUsers.Where(u => rolesSelected.Contains(u.Role)).ToList();
        
        foreach (var user in targetUsers)
        {
            var notification = new Notification
            {
                Id = Guid.NewGuid(),
                UserId = user.Id,
                Message = Message,
                Type = NotificationType.Announcement,
                CreatedAt = DateTime.Now,
                IsRead = false
            };
            NotificationService.SendNotification(notification);
        }

        SuccessMessage = $"Announcement sent to {targetUsers.Count} user(s) across {rolesSelected.Count} role(s)!";
        Message = string.Empty;
        SendToAdmin = false;
        SendToFaculty = false;
        SendToStudent = false;
    }

    private void ClearSuccess()
    {
        SuccessMessage = string.Empty;
    }
}

@page "/admin/courses"

<PageTitle>EduConnect - Course Management</PageTitle>

@using EduConnect.Interfaces
@using EduConnect.Models
@using EduConnect.Models.Enums
@namespace EduConnect.Components.Pages.Admin

@inject ICourseService CourseService
@inject IAuthStateService AuthStateService
@inject NavigationManager NavigationManager

<AuthGuard AllowedRoles="new[] { UserRole.Admin }">
    <div class="container-fluid mt-4">
        <h2>Course Management</h2>
        <button class="btn btn-primary mb-3" @onclick="ShowAddForm">Add New Course</button>

        @if (ShowNewCourseForm)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5>@(IsEditMode ? "Edit Course" : "Add New Course")</h5>
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@ErrorMessage</div>
                    }
                    <form @onsubmit="@(IsEditMode? UpdateCourse : AddCourse)">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Course Code</label>
                                <input type="text" class="form-control" @bind="newCourse.Code" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Title</label>
                                <input type="text" class="form-control" @bind="newCourse.Title" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Credit Hours</label>
                                <input type="number" class="form-control" @bind="newCourse.CreditHours" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Max Capacity</label>
                                <input type="number" class="form-control" @bind="newCourse.MaxCapacity" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Assign Faculty</label>
                                <select class="form-select" @bind="newCourse.FacultyId">
                                    <option value="0">-- Select Faculty --</option>
                                    @if (facultyMembers != null)
                                    {
                                        @foreach (var faculty in facultyMembers)
                                        {
                                            <option value="@faculty.Id">@faculty.FullName (@faculty.Department)</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <button type="submit" class="btn @(IsEditMode ? "btn-warning" : "btn-success") btn-sm">@(IsEditMode
                                                    ? "Update" : "Add")</button>
                            <button type="button" class="btn btn-secondary btn-sm" @onclick="HideAddForm">Cancel</button>
                        </form>
                    </div>
                </div>
            }

            @if (courses == null)
            {
                <p>Loading...</p>
            }
            else if (courses.Count == 0)
            {
                <div class="alert alert-primary">No courses found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Title</th>
                                <th>Credit Hours</th>
                                <th>Capacity</th>
                                <th>Enrolled</th>
                                <th>Faculty</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var course in courses)
                            {
                                <tr>
                                    <td>@course.Code</td>
                                    <td>@course.Title</td>
                                    <td>@course.CreditHours</td>
                                    <td>@course.MaxCapacity</td>
                                    <td>@course.EnrollmentCount</td>
                                    <td>@GetFacultyName(course.FacultyId)</td>
                                    <td><span
                                        class="badge bg-@GetStatusColor(course.EnrollmentStatus)">@course.EnrollmentStatus</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" @onclick="() => EditCourse(course)">Edit</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteCourse(course)">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </AuthGuard>

@code {
    private List<Course>? courses;
    private List<Faculty>? facultyMembers;
    private Course newCourse = new();
    private bool ShowNewCourseForm = false;
    private bool IsEditMode = false;
    private string ErrorMessage = string.Empty;

    protected override void OnInitialized()
    {
        RefreshCourses();
        LoadFaculty();
    }

    private void LoadFaculty()
    {
        facultyMembers = AuthStateService.GetAllUsers()
            .OfType<Faculty>()
            .ToList();
    }

    private void RefreshCourses()
    {
        courses = CourseService.GetAll();
    }

    private void ShowAddForm()
    {
        ShowNewCourseForm = true;
        IsEditMode = false;
        ErrorMessage = string.Empty;
        newCourse = new Course();
    }

    private void HideAddForm()
    {
        ShowNewCourseForm = false;
        IsEditMode = false;
        ErrorMessage = string.Empty;
        newCourse = new Course();
    }

    private void AddCourse()
    {
        ErrorMessage = string.Empty;

        // Validate course code is not empty
        if (string.IsNullOrWhiteSpace(newCourse.Code))
        {
            ErrorMessage = "Course code is required.";
            return;
        }

        // Check if course code already exists
        if (CourseService.CourseCodeExists(newCourse.Code))
        {
            ErrorMessage = $"A course with code '{newCourse.Code}' already exists. Please use a different code.";
            return;
        }

        // Validate other required fields
        if (string.IsNullOrWhiteSpace(newCourse.Title))
        {
            ErrorMessage = "Course title is required.";
            return;
        }

        if (newCourse.CreditHours <= 0)
        {
            ErrorMessage = "Credit hours must be greater than 0.";
            return;
        }

        if (newCourse.MaxCapacity <= 0)
        {
            ErrorMessage = "Max capacity must be greater than 0.";
            return;
        }

        if (newCourse.FacultyId == 0)
        {
            ErrorMessage = "Please assign a faculty member to this course.";
            return;
        }

        CourseService.Add(newCourse);
        RefreshCourses();
        HideAddForm();
    }

    private void EditCourse(Course course)
    {
        ShowNewCourseForm = true;
        IsEditMode = true;
        ErrorMessage = string.Empty;
        newCourse = new Course
        {
            Id = course.Id,
            Code = course.Code,
            Title = course.Title,
            CreditHours = course.CreditHours,
            MaxCapacity = course.MaxCapacity,
            FacultyId = course.FacultyId
        };
    }

    private void UpdateCourse()
    {
        ErrorMessage = string.Empty;

        // Validate course code is not empty
        if (string.IsNullOrWhiteSpace(newCourse.Code))
        {
            ErrorMessage = "Course code is required.";
            return;
        }

        // Check if course code already exists (excluding the current course)
        if (CourseService.CourseCodeExists(newCourse.Code, newCourse.Id))
        {
            ErrorMessage = $"A course with code '{newCourse.Code}' already exists. Please use a different code.";
            return;
        }

        // Validate other required fields
        if (string.IsNullOrWhiteSpace(newCourse.Title))
        {
            ErrorMessage = "Course title is required.";
            return;
        }

        if (newCourse.CreditHours <= 0)
        {
            ErrorMessage = "Credit hours must be greater than 0.";
            return;
        }

        if (newCourse.MaxCapacity <= 0)
        {
            ErrorMessage = "Max capacity must be greater than 0.";
            return;
        }

        if (newCourse.FacultyId == 0)
        {
            ErrorMessage = "Please assign a faculty member to this course.";
            return;
        }

        CourseService.Update(newCourse);
        RefreshCourses();
        HideAddForm();
    }

    private void DeleteCourse(Course course)
    {
        CourseService.Delete(course.Id);
        RefreshCourses();
    }

    private string GetFacultyName(int facultyId)
    {
        var faculty = facultyMembers?.FirstOrDefault(f => f.Id == facultyId);
        return faculty?.FullName ?? "Unassigned";
    }

    private string GetStatusColor(EnrollmentStatus status) => status switch
    {
        EnrollmentStatus.Open => "success",
        EnrollmentStatus.AlmostFull => "warning",
        _ => "danger"
    };
}

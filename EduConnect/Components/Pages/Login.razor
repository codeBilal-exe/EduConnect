@page "/"
@page "/login"

@using EduConnect.Interfaces
@using EduConnect.Models.Enums
@namespace EduConnect.Components.Pages

@inject IAuthStateService AuthStateService
@inject NavigationManager NavigationManager

@layout Layout.LoginLayout

<div class="container-fluid d-flex align-items-center justify-content-center px-3"
     style="min-height: 100vh; background: linear-gradient(135deg, var(--brand-navy) 0%, var(--brand-blue) 100%); overflow: hidden; position: relative;">
    
    @* Decorative background elements *@
    <div style="position: absolute; top: -10%; left: -5%; width: 400px; height: 400px; background: rgba(216, 159, 42, 0.1); border-radius: 50%; filter: blur(80px);"></div>
    <div style="position: absolute; bottom: -10%; right: -5%; width: 300px; height: 300px; background: rgba(255, 255, 255, 0.05); border-radius: 50%; filter: blur(60px);"></div>

    <div class="card shadow-2xl border-0 rounded-4 glass-panel"
         style="max-width: 450px; width: 100%; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5) !important;">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="d-inline-block p-3 rounded-circle bg-white shadow-sm mb-3">
                    <img src="favicon.png" alt="EduConnect Logo" style="width: 60px; height: 60px;" />
                </div>
                <h2 class="fw-bold text-white mb-1" style="letter-spacing: -0.5px;">EduConnect</h2>
                <p class="text-white text-opacity-75 small mb-0">Sign in to your academic portal</p>
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white small rounded-3 mb-4 d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div class="flex-grow-1">@ErrorMessage</div>
                    <button type="button" class="btn-close btn-close-white small shadow-none" @onclick="ClearError" style="font-size: 0.5rem;"></button>
                </div>
            }

            <form @onsubmit="HandleLogin">
                <div class="mb-3">
                    <label for="email" class="form-label text-white text-opacity-75 small fw-semibold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white bg-opacity-10 border-0 text-white"><i class="bi bi-envelope"></i></span>
                        <input type="email" class="form-control bg-white bg-opacity-10 border-0 text-white placeholder-light" id="email" @bind="Email" placeholder="Enter your email" style="box-shadow: none;">
                    </div>
                </div>
                <div class="mb-4">
                    <label for="password" class="form-label text-white text-opacity-75 small fw-semibold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white bg-opacity-10 border-0 text-white"><i class="bi bi-lock"></i></span>
                        <input type="@(ShowPassword ? "text" : "password")" 
                               class="form-control bg-white bg-opacity-10 border-0 text-white placeholder-light" 
                               id="password" @bind="Password" placeholder="Enter your password" style="box-shadow: none;">
                        <button type="button" class="input-group-text bg-white bg-opacity-10 border-0 text-white shadow-none" 
                                @onclick="() => ShowPassword = !ShowPassword" title="@(ShowPassword ? "Hide Password" : "Show Password")">
                            <i class="bi @(ShowPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                </div>
        
                <button type="submit" class="btn btn-accent btn-lg w-100 fw-bold rounded-3 mb-3 shadow-lg border-0 py-3"
                        style="letter-spacing: 1px; transition: all 0.3s ease;">
                    SIGN IN
                </button>
            </form>

            <div class="text-center mt-2">
                <p class="text-white text-opacity-50 small mb-0">
                    Secure Academic Portal Access &bull; Spring 2026
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Glassmorphism utility */
    .glass-panel {
        background: rgba(255, 255, 255, 0.1) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
    }
    .placeholder-light::placeholder {
        color: rgba(255, 255, 255, 0.4) !important;
    }
    .form-control:focus {
        background-color: rgba(255, 255, 255, 0.15) !important;
        color: white !important;
    }
    .btn-accent:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
        box-shadow: 0 8px 20px rgba(216, 159, 42, 0.4);
    }
</style>

@code {
    private string Email = string.Empty;
    private string Password = string.Empty;
    private string ErrorMessage = string.Empty;
    private bool ShowPassword = false;

    private void HandleLogin()
    {
        ErrorMessage = string.Empty;

        if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Password))
        {
            ErrorMessage = "Email and password are required.";
            return;
        }

        if (AuthStateService.Login(Email, Password))
        {
            NavigationManager.NavigateTo("/dashboard");
        }
        else
        {
            ErrorMessage = "Wrong Credentials !!";
        }
    }

    private void ClearError()
    {
        ErrorMessage = string.Empty;
    }
}

@page "/faculty/grades"
<PageTitle>EduConnect - Grade Entry</PageTitle>
@using EduConnect.Interfaces
@using EduConnect.Models
@namespace EduConnect.Components.Pages.Faculty

@inject IGradeService GradeService
@inject ICourseService CourseService
@inject IAuthStateService AuthStateService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <h2>Grade Entry</h2>

    @if (assignedCourses == null || assignedCourses.Count == 0)
    {
        <div class="alert alert-info">You have no assigned courses.</div>
    }
    else
    {
        <div class="mb-3">
            <label class="form-label">Select Course</label>
            <select class="form-control" @onchange="HandleCourseSelected">
                <option value="">-- Select a Course --</option>
                @foreach (var course in assignedCourses)
                {
                    <option value="@course.Id">@course.Code - @course.Title</option>
                }
            </select>
        </div>

        @if (selectedCourse != null)
        {
            <div class="card">
                <div class="card-body">
                    <h5>Enter Grades for @selectedCourse.Title</h5>
                    @if (enrolledStudents != null && enrolledStudents.Count > 0)
                    {
                        <form @onsubmit="SubmitGrades">
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Student Name</th>
                                            <th>Email</th>
                                            <th>Marks (0-100)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var studentId in selectedCourse.EnrolledStudentIds)
                                        {
                                            var student = GetStudent(studentId);
                                            if (student != null)
                                            {
                                                <tr>
                                                    <td>@student.FullName</td>
                                                    <td>@student.Email</td>
                                                    <td>
                                                        <input type="number" class="form-control" min="0" max="100"
                                                               @onchange="@((ChangeEventArgs e) => UpdateMarks(studentId, e))" />
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <button type="submit" class="btn btn-primary">Submit Grades</button>
                        </form>
                    }
                    else
                    {
                        <p>No enrolled students in this course.</p>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Course>? assignedCourses;
    private Course? selectedCourse;
    private List<Student>? enrolledStudents;
    private Dictionary<Guid, double> gradeMarks = new();

    protected override void OnInitialized()
    {
        var userId = AuthStateService.CurrentUser?.Id;
        if (!userId.HasValue)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        // Get courses assigned to this faculty
        assignedCourses = CourseService.GetCoursesByFaculty(userId.Value);
    }

    private void HandleCourseSelected(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var courseId))
        {
            selectedCourse = CourseService.GetById(courseId);
            if (selectedCourse != null)
            {
                enrolledStudents = new List<Student>();
                gradeMarks.Clear();
            }
        }
    }

    private Student? GetStudent(Guid studentId)
    {
        // This would normally be fetched from StudentService
        // For now, returning null
        return null;
    }

    private void UpdateMarks(Guid studentId, ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var marks))
        {
            gradeMarks[studentId] = marks;
        }
    }

    private void SubmitGrades()
    {
        if (selectedCourse == null)
            return;

        foreach (var (studentId, marks) in gradeMarks)
        {
            var grade = new GradeRecord
            {
                Id = Guid.NewGuid(),
                StudentId = studentId,
                CourseId = selectedCourse.Id,
                Marks = marks
            };

            GradeService.SubmitGrade(grade);
        }

        // Clear form
        selectedCourse = null;
        gradeMarks.Clear();
    }
}

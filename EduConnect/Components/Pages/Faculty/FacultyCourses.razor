@page "/faculty/courses"
@rendermode InteractiveServer


<PageTitle>EduConnect - Faculty Courses</PageTitle>

@using EduConnect.Interfaces
@using EduConnect.Models
@using EduConnect.Models.Enums
@using EduConnect.Components.Shared
@namespace EduConnect.Components.Pages.Faculty

@inject ICourseService CourseService
@inject IStudentService StudentService
@inject IAuthStateService AuthStateService
@inject NavigationManager NavigationManager


<AuthGuard AllowedRoles="new[] { UserRole.Faculty }">
    <div class="container-fluid mt-4">
        <h2>My Assigned Courses</h2>

        @if (assignedCourses == null)
        {
            <LoadingSpinner IsLoading="true" />
        }
        else if (assignedCourses.Count == 0)
        {
            <div class="alert alert-primary">You have no assigned courses.</div>
        }
        else
        {
            <div class="row">
                @foreach (var course in assignedCourses)
                {
                    <div class="col-md-6 mb-4">
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <h5>@course.Code - @course.Title</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Credit Hours:</strong> @course.CreditHours</p>
                                <p><strong>Capacity:</strong> @course.EnrollmentCount / @course.MaxCapacity</p>
                                <p><strong>Status:</strong> <span
                                    class="badge bg-@GetStatusColor(course.EnrollmentStatus)">@course.EnrollmentStatus</span>
                                </p>
                                <div class="progress mb-3">
                                    <div class="progress-bar" role="progressbar" style="width: @GetProgressPercentage(course)%;"
                                         aria-valuenow="@course.EnrollmentCount" aria-valuemin="0"
                                         aria-valuemax="@course.MaxCapacity">
                                    </div>
                                </div>
                                <a href="/faculty/grades" class="btn btn-primary btn-sm">Enter Grades</a>
                                <button class="btn btn-primary btn-sm" @onclick="() => ViewEnrollments(course)">View Enrolled
                                    Students</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (SelectedCourse != null)
                {
                    <div class="card mt-4 border-info shadow-sm">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Enrolled Students: @SelectedCourse.Title</h5>
                            <button class="btn btn-sm btn-light" @onclick="() => SelectedCourse = null">Close</button>
                        </div>
                        <div class="card-body">
                            @if (EnrolledStudents == null)
                            {
                                <div class="text-center py-4">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                </div>
                            }
                            else if (EnrolledStudents.Count == 0)
                            {
                                <div class="text-center py-4">
                                    <i class="bi bi-people text-muted fs-1"></i>
                                    <p class="text-muted mt-2">No students are currently enrolled in this course.</p>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Student Name</th>
                                                <th>Email Address</th>
                                                <th class="text-center">Semester</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var student in EnrolledStudents.OrderBy(s => s.FullName))
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="fw-bold">@student.FullName</div>
                                                    </td>
                                                    <td>@student.Email</td>
                                                    <td class="text-center">
                                                        <span class="badge bg-primary">Semester @student.Semester</span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </AuthGuard>

@code {
    private List<Course>? assignedCourses;
    private Course? SelectedCourse { get; set; }
    private List<Student>? EnrolledStudents { get; set; }

    protected override void OnInitialized()
    {
        var userId = AuthStateService.CurrentUser?.Id;
        if (userId.HasValue)
        {
            assignedCourses = CourseService.GetCoursesByFaculty(userId.Value);
        }
    }

    private async Task ViewEnrollments(Course course)
    {
        SelectedCourse = course;
        EnrolledStudents = null; // Show spinner
        StateHasChanged();

        await Task.Delay(100); // Small delay to ensure spinner is visible and UI is responsive

        if (course.EnrolledStudentIds != null)
        {
            EnrolledStudents = course.EnrolledStudentIds
                .Select(id => StudentService.GetById(id))
                .Where(s => s != null)
                .Cast<Student>()
                .ToList();
        }
        else
        {
            EnrolledStudents = new List<Student>();
        }
        
        StateHasChanged();
    }




    private string GetStatusColor(EnrollmentStatus status) => status switch
    {
        EnrollmentStatus.Open => "success",
        EnrollmentStatus.AlmostFull => "warning",
        _ => "danger"
    };

    private int GetProgressPercentage(Course course)
    {
        if (course.MaxCapacity == 0)
            return 0;
        return (int)((course.EnrollmentCount / (double)course.MaxCapacity) * 100);
    }
}

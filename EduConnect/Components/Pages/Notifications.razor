@page "/notifications"

<PageTitle>EduConnect - Notifications</PageTitle>

@using EduConnect.Interfaces
@using EduConnect.Models
@namespace EduConnect.Components.Pages

@inject INotificationService NotificationService
@inject IAuthStateService AuthStateService
@inject NavigationManager NavigationManager

@implements IAsyncDisposable

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Notifications</h2>
            <p class="text-muted small">Manage your alerts and course updates</p>
        </div>
        @if (notifications?.Any(n => !n.IsRead) == true)
        {
            <button class="btn btn-outline-primary btn-sm rounded-pill px-3" @onclick="MarkAllAsRead">
                <i class="bi bi-check2-all me-1"></i> Mark all as read
            </button>
        }
    </div>

    @if (notifications == null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (notifications.Count == 0)
    {
        <div class="text-center py-5 glass-panel rounded-4">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="bi bi-bell-slash text-muted fs-1"></i>
            </div>
            <h4 class="fw-bold">No notifications yet</h4>
            <p class="text-muted">When you get alerts about your courses or grades, they'll appear here.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var notif in notifications)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-3 @(notif.IsRead ? "bg-light opacity-75" : "border-start border-4 border-primary")">
                        <div class="card-body p-3">
                            <div class="d-flex gap-3">
                                <div class="flex-shrink-0">
                                    <div class="rounded-circle bg-@GetNotifColor(notif.Type)-subtle p-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                        <i class="bi @GetNotifIcon(notif.Type) text-@GetNotifColor(notif.Type) fs-4"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h6 class="fw-bold mb-1">@GetNotifTitle(notif.Type)</h6>
                                        <small class="text-muted">@notif.CreatedAt.ToString("MMM dd, h:mm tt")</small>
                                    </div>
                                    <p class="mb-2 text-secondary">@notif.Message</p>
                                    @if (!notif.IsRead)
                                    {
                                        <button class="btn btn-link btn-sm p-0 text-decoration-none fw-semibold" @onclick="() => MarkAsRead(notif.Id)">
                                            Mark as read
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Notification>? notifications;

    protected override void OnInitialized()
    {
        var userId = AuthStateService.CurrentUser?.Id;
        if (!userId.HasValue)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        notifications = NotificationService.GetNotificationsForUser(userId.Value);
        NotificationService.OnNewNotification += HandleNewNotification;
    }

    private void HandleNewNotification(Notification notif)
    {
        var userId = AuthStateService.CurrentUser?.Id;
        if (notif.StudentId == userId)
        {
            notifications?.Insert(0, notif);
            StateHasChanged();
        }
    }

    private void MarkAsRead(int notificationId)
    {
        NotificationService.MarkAsRead(notificationId);
        var notif = notifications?.FirstOrDefault(n => n.Id == notificationId);
        if (notif != null)
        {
            notif.IsRead = true;
        }
        StateHasChanged();
    }

    private void MarkAllAsRead()
    {
        var userId = AuthStateService.CurrentUser?.Id;
        if (userId.HasValue && notifications != null)
        {
            var unread = notifications.Where(n => !n.IsRead).ToList();
            foreach (var notif in unread)
            {
                NotificationService.MarkAsRead(notif.Id);
                notif.IsRead = true;
            }
            StateHasChanged();
        }
    }

    private string GetNotifColor(NotificationType type) => type switch
    {
        NotificationType.Announcement => "danger",
        NotificationType.Enrollment => "info",
        NotificationType.GradePosted => "success",
        _ => "primary"
    };

    private string GetNotifIcon(NotificationType type) => type switch
    {
        NotificationType.Announcement => "bi-megaphone-fill",
        NotificationType.Enrollment => "bi-journal-plus",
        NotificationType.GradePosted => "bi-mortarboard-fill",
        _ => "bi-bell-fill"
    };

    private string GetNotifTitle(NotificationType type) => type switch
    {
        NotificationType.Announcement => "Announcement",
        NotificationType.Enrollment => "Course Enrollment",
        NotificationType.GradePosted => "Grade Posted",
        _ => "Notification"
    };

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        NotificationService.OnNewNotification -= HandleNewNotification;
        return ValueTask.CompletedTask;
    }
}

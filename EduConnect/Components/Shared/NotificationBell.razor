@using EduConnect.Interfaces
@using EduConnect.Models
@namespace EduConnect.Components.Shared

@implements IAsyncDisposable

@if (ShowDropdown)
{
    @* Transparent overlay to handle 'click outside' to close *@
    <div @onclick="ToggleDropdown" 
         style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1040; background: transparent;">
    </div>
}

<div class="btn-group" role="group">
    <button type="button" class="btn btn-link text-white p-0 position-relative shadow-none" @onclick="ToggleDropdown"
            style="text-decoration: none; z-index: 1051;">
        <i class="bi bi-bell-fill fs-5"></i>
        @if (UnreadCount > 0)
        {
            <span
                class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-2 border-primary"
                style="font-size: 0.65rem; padding: 0.25em 0.5em;">
                @UnreadCount
            </span>
        }
    </button>
    @if (ShowDropdown)
    {
        <div class="dropdown-menu dropdown-menu-end show p-0 shadow-lg border-0 mt-2"
             style="min-width: 340px; right: 0; left: auto; z-index: 1050; border-radius: 12px; overflow: hidden;">
            <div class="card border-0">
                <div class="card-header border-bottom py-3 px-3 d-flex justify-content-between align-items-center"
                     style="background-color: white !important; border-bottom: 1px solid #eee !important;">
                    <h6 class="mb-0 fw-bold text-dark">Notifications</h6>
                    <div class="d-flex gap-2 align-items-center">
                        @if (UnreadCount > 0)
                        {
                            <button class="btn btn-sm btn-link text-primary text-decoration-none p-0 small fw-semibold" 
                                    @onclick="MarkAllAsRead" style="font-size: 0.7rem;">Mark all as read</button>
                            <span class="text-muted text-opacity-25">|</span>
                        }
                        <a href="/notifications" class="text-primary text-decoration-none small fw-semibold"
                           @onclick="ToggleDropdown" style="font-size: 0.7rem;">View All</a>
                    </div>
                </div>

                <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                    @if (RecentNotifications != null && RecentNotifications.Count > 0)
                    {
                        @foreach (var notif in RecentNotifications)
                        {
                            <div @onclick="() => HandleNotifClick(notif)"
                                 class="list-group-item list-group-item-action border-0 border-bottom px-3 py-3 @(notif.IsRead ? "opacity-75" : "bg-light-subtle")"
                                 style="cursor: pointer;">
                                <div class="d-flex w-100 justify-content-between align-items-start mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-@GetNotifColor(notif.Type) p-1"
                                             style="width: 8px; height: 8px;"></div>
                                        <span class="fw-bold small text-dark">@GetNotifTitle(notif.Type)</span>
                                    </div>
                                    <small class="text-muted" style="font-size: 0.7rem;">@GetTimeAgo(notif.CreatedAt)</small>
                                </div>
                                <p class="mb-0 small text-secondary"
                                        style="font-size: 0.825rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @notif.Message
                                </p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-5 text-center">
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                 style="width: 60px; height: 60px;">
                                <i class="bi bi-bell-slash text-muted fs-3"></i>
                            </div>
                            <h6 class="text-dark fw-bold small">All caught up!</h6>
                            <p class="text-muted mb-0" style="font-size: 0.75rem;">No new notifications to show right now.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>



@code {
    [Inject]
    private INotificationService? NotificationService { get; set; }

    [Inject]
    private IAuthStateService? AuthStateService { get; set; }

    private bool ShowDropdown = false;
    private int UnreadCount = 0;
    private List<Notification> RecentNotifications = new();

    protected override void OnInitialized()
    {
        if (NotificationService != null)
        {
            NotificationService.OnNewNotification += OnNotificationReceived;
            NotificationService.OnNotificationMarkedAsRead += OnNotificationMarkedAsRead;
            LoadNotifications();
        }
    }

    private async void OnNotificationReceived(Notification notification)
    {
        await InvokeAsync(() =>
        {
            var currentUserId = AuthStateService?.CurrentUser?.Id;
            if (currentUserId.HasValue && notification.UserId == currentUserId.Value)
            {
                LoadNotifications();
                StateHasChanged();
            }
        });
    }

    private async void OnNotificationMarkedAsRead(Guid notificationId)
    {
        await InvokeAsync(() =>
        {
            LoadNotifications();
            StateHasChanged();
        });
    }

    private void ToggleDropdown()
    {
        ShowDropdown = !ShowDropdown;
        if (ShowDropdown)
        {
            LoadNotifications();
        }
    }

    private void HandleNotifClick(Notification notif)
    {
        if (!notif.IsRead && NotificationService != null)
        {
            NotificationService.MarkAsRead(notif.Id);
        }
    }

    private void MarkAllAsRead()
    {
        if (NotificationService != null && AuthStateService?.CurrentUser != null)
        {
            var userId = AuthStateService.CurrentUser.Id;
            var unread = NotificationService.GetNotificationsForUser(userId).Where(n => !n.IsRead);
            foreach (var notif in unread)
            {
                NotificationService.MarkAsRead(notif.Id);
            }
        }
    }

    private void LoadNotifications()
    {
        if (NotificationService != null && AuthStateService?.CurrentUser != null)
        {
            var userId = AuthStateService.CurrentUser.Id;
            var allNotifications = NotificationService.GetNotificationsForUser(userId);
            RecentNotifications = allNotifications.Take(5).ToList();
            UnreadCount = NotificationService.GetUnreadCount(userId);
        }
    }

    private string GetNotifColor(NotificationType type) => type switch
    {
        NotificationType.Announcement => "danger",
        NotificationType.Enrollment => "info",
        NotificationType.GradePosted => "success",
        _ => "primary"
    };

    private string GetNotifTitle(NotificationType type) => type switch
    {
        NotificationType.Announcement => "Announcement",
        NotificationType.Enrollment => "Course Update",
        NotificationType.GradePosted => "Grade Posted",
        _ => "Notification"
    };

    private string GetTimeAgo(DateTime dateTime)
    {
        var diff = DateTime.Now - dateTime;
        if (diff.TotalDays >= 1) return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalHours >= 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalMinutes >= 1) return $"{(int)diff.TotalMinutes}m ago";
        return "Just now";
    }

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (NotificationService != null)
        {
            NotificationService.OnNewNotification -= OnNotificationReceived;
            NotificationService.OnNotificationMarkedAsRead -= OnNotificationMarkedAsRead;
        }
        return ValueTask.CompletedTask;
    }
}


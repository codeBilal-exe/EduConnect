@namespace EduConnect.Components.Shared

@if (IsLoading)
{
    <div class="text-center p-4">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsLoading { get; set; } = false;
}

@namespace EduConnect.Components.Shared
@using EduConnect.Interfaces
@using EduConnect.Models
@using EduConnect.Models.Enums

@inject IAuthStateService AuthStateService
@inject IStudentService StudentService
@inject ICourseService CourseService

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">My Profile</h5>
                @if (CurrentStudent != null)
                {
                    <p><strong>Semester:</strong> @CurrentStudent.Semester</p>
                    <p><strong>Email:</strong> @CurrentStudent.Email</p>
                    <p><strong>CGPA:</strong> <span class="badge bg-primary">@ComputedCGPA.ToString("F2")</span></p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Quick Actions</h5>
                <a href="/courses" class="btn btn-primary btn-sm me-2">Browse Courses</a>
                <a href="/student/enroll" class="btn btn-primary btn-sm me-2">Enroll in Courses</a>
                <a href="/student/enrolled-courses" class="btn btn-primary btn-sm me-2">My Enrolled Courses</a>
                <a href="/student/grades" class="btn btn-primary btn-sm">View My Grades</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">My Enrolled Courses</h5>
            </div>
            <div class="card-body">
                @if (EnrolledCourses == null)
                {
                    <p>Loading courses...</p>
                }
                else if (EnrolledCourses.Count == 0)
                {
                    <p class="text-muted mb-0">You are not enrolled in any courses yet. <a href="/student/enroll">Enroll
                        now</a></p>
                    }
                else
                    {
                        <div class="row">
                            @foreach (var course in EnrolledCourses)
                            {
                                <div class="col-md-6 col-lg-4 mb-3">
                                    <div class="card border-start border-primary" style="border-width: 4px;">
                                        <div class="card-body">
                                            <h6 class="card-title text-primary">@course.Code</h6>
                                            <p class="card-text small mb-2">@course.Title</p>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="badge bg-primary">@course.CreditHours cr</span>
                                                <a href="/student/grades" class="btn btn-sm btn-outline-primary">View Grade</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-3">
                            <a href="/student/enrolled-courses" class="btn btn-sm btn-outline-primary">View All Courses</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

@code {
    private Student? CurrentStudent;
    private double ComputedCGPA = 0.0;
    private List<Course> EnrolledCourses = new();

    protected override void OnInitialized()
    {
        var currentUserId = AuthStateService?.CurrentUser?.Id;
        if (currentUserId.HasValue)
        {
            CurrentStudent = StudentService.GetById(currentUserId.Value);
            ComputedCGPA = StudentService.ComputeCGPA(currentUserId.Value);
            
            // Load enrolled courses
            var allCourses = CourseService.GetAll();
            EnrolledCourses = allCourses
                .Where(c => c.EnrolledStudentIds.Contains(currentUserId.Value))
                .OrderBy(c => c.Code)
                .ToList();
        }
    }
}

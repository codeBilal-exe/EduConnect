@namespace EduConnect.Components.Shared
@using EduConnect.Interfaces

@inject IStudentService StudentService

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Quick Actions</h5>
                <a href="/admin/students" class="btn btn-primary btn-sm w-100 mb-2">Manage Students</a>
                <a href="/admin/courses" class="btn btn-primary btn-sm w-100 mb-2">Manage Courses</a>
                <a href="/admin/reports/grades" class="btn btn-primary btn-sm w-100 mb-2">View Grade Reports</a>
                <a href="/admin/notifications" class="btn btn-primary btn-sm w-100">Send Announcements</a>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">System Statistics</h5>
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Total Students:</strong> @StudentService.GetAll().Count</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {

}
